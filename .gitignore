# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ---- virtual environments ----
venv/
.venv/
env/
ENV/

# ---- generated outputs ----
# Figures and result tables are regenerated by `python src/main.py`.
# The committed copies in assets/ are the versions used in the paper;
# fresh runs write here first, so keep run artefacts out of git.
src/*.png
src/*.csv
src/run_log.txt
!src/__init__.py

# ---- editors / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- keep the dataset ----
# dataset/ is intentionally NOT ignored: 1.8 MB, CC-BY 4.0, and committing it
# makes the repository reproducible with a single command.
